---
import { $astroCount } from "@stores/handling-state/independentCounterStore";
---

<div class="bg-astro-100 rounded-lg p-4 shadow-md">
  <h2 class="text-astro-800 mb-4 text-center text-2xl font-bold">Independent Astro Counter</h2>
  <div class="flex items-center justify-center gap-6 text-3xl font-semibold">
    <button
      id="astroDecrement-iso"
      class="bg-astro-500 hover:bg-astro-600 rounded px-4 py-2 text-white transition-colors"
    >
      -
    </button>
    <p id="astroCount-iso" class="text-astro-600">{$astroCount.get()}</p>

    <button
      id="astroIncrement-iso"
      class="bg-astro-500 hover:bg-astro-600 rounded px-4 py-2 text-white transition-colors"
    >
      +
    </button>
  </div>
</div>

<script>
  import {
    $astroCount,
    astroIncrement,
    astroDecrement,
  } from "@stores/handling-state/independentCounterStore";

  const decrementBtn = document.getElementById("astroDecrement-iso");
  const incrementBtn = document.getElementById("astroIncrement-iso");
  const countDisplay = document.getElementById("astroCount-iso");

  decrementBtn?.addEventListener("click", () => {
    astroDecrement();
  });

  incrementBtn?.addEventListener("click", () => {
    astroIncrement();
  });

  // Subscribe to store changes
  $astroCount.subscribe((value) => {
    if (countDisplay) {
      countDisplay.textContent = value.toString();
    }
  });
</script>
