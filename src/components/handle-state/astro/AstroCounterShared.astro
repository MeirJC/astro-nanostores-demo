---
import { $count } from "@stores/handling-state/sharedCounterStore";
---

<div class="bg-astro-100 rounded-lg p-4 shadow-md">
  <h2 class="text-astro-800 mb-4 text-center text-2xl font-bold">Astro Counter (Shared State)</h2>
  <div class="flex items-center justify-center gap-6 text-3xl font-semibold">
    <button
      id="astroDecrement"
      class="bg-astro-500 hover:bg-astro-600 rounded px-4 py-2 text-white transition-colors"
    >
      -
    </button>
    <p id="astroCount" class="text-astro-600">{$count.get()}</p>
    <button
      id="astroIncrement"
      class="bg-astro-500 hover:bg-astro-600 rounded px-4 py-2 text-white transition-colors"
    >
      +
    </button>
  </div>
</div>

<script>
  import { $count, increment, decrement } from "@stores/handling-state/sharedCounterStore";

  const decrementBtn = document.getElementById("astroDecrement");
  const incrementBtn = document.getElementById("astroIncrement");
  const countDisplay = document.getElementById("astroCount");

  decrementBtn?.addEventListener("click", () => {
    decrement();
  });

  incrementBtn?.addEventListener("click", () => {
    increment();
  });

  // Subscribe to store changes
  $count.subscribe((value) => {
    if (countDisplay) {
      countDisplay.textContent = value.toString();
    }
  });
</script>
