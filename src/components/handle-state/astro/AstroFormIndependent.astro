---
import { $astroFormState } from "@stores/handling-state/independentFormStore";
---

<form id="astroIsoForm" class="bg-astro-100 rounded-lg p-4 text-black shadow-md">
  <h2 class="text-astro-800 mb-4 text-center text-2xl font-bold">Independent Astro Form</h2>
  <div class="space-y-4">
    <div>
      <label for="astro-iso-firstName" class="text-astro-700 block text-sm font-medium"
        >First Name</label
      >
      <input
        type="text"
        id="astro-iso-firstName"
        name="firstName"
        value={$astroFormState.get().firstName}
        class="border-astro-300 focus:border-astro-500 focus:ring-astro-200 mt-1 block w-full rounded-md shadow-xs focus:ring"
      />
    </div>
    <div>
      <label for="astro-iso-lastName" class="text-astro-700 block text-sm font-medium"
        >Last Name</label
      >
      <input
        type="text"
        id="astro-iso-lastName"
        name="lastName"
        value={$astroFormState.get().lastName}
        class="border-astro-300 focus:border-astro-500 focus:ring-astro-200 mt-1 block w-full rounded-md shadow-xs focus:ring"
      />
    </div>
    <div>
      <label for="astro-iso-email" class="text-astro-700 block text-sm font-medium">Email</label>
      <input
        type="email"
        id="astro-iso-email"
        name="email"
        value={$astroFormState.get().email}
        class="border-astro-300 focus:border-astro-500 focus:ring-astro-200 mt-1 block w-full rounded-md shadow-xs focus:ring"
      />
    </div>
    <div>
      <label for="astro-iso-password" class="text-astro-700 block text-sm font-medium"
        >Password</label
      >
      <input
        type="password"
        id="astro-iso-password"
        name="password"
        value={$astroFormState.get().password}
        class="border-astro-300 focus:border-astro-500 focus:ring-astro-200 mt-1 block w-full rounded-md shadow-xs focus:ring"
      />
    </div>
    <div class="flex items-center">
      <input
        type="checkbox"
        id="astro-iso-agreeTerms"
        name="agreeTerms"
        checked={$astroFormState.get().agreeTerms}
        class="border-astro-300 text-astro-600 focus:ring-astro-500 h-4 w-4 rounded"
      />
      <label for="astro-iso-agreeTerms" class="text-astro-700 ml-2 block text-sm"
        >I agree to the terms and conditions</label
      >
    </div>
  </div>
  <div class="mt-6">
    <button
      type="submit"
      class="bg-astro-500 hover:bg-astro-600 w-full rounded px-4 py-2 text-white transition-colors"
    >
      Submit
    </button>
  </div>
</form>

<script>
  import { $astroFormState } from "@stores/handling-state/independentFormStore";

  const form = document.getElementById("astroIsoForm");

  form?.addEventListener("input", (event) => {
    const target = event.target as HTMLInputElement;
    const { name, value, type, checked } = target;
    $astroFormState.setKey(
      name as keyof import("@stores/handling-state/independentFormStore").FormData,
      type === "checkbox" ? checked : value
    );
  });

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    console.log("Astro Form Submitted:", $astroFormState.get());
  });

  $astroFormState.subscribe((state) => {
    Object.entries(state).forEach(([key, value]) => {
      const element = document.getElementById(`astro-iso-${key}`) as HTMLInputElement;
      if (element) {
        if (element.type === "checkbox") {
          element.checked = value as boolean;
        } else {
          element.value = value as string;
        }
      }
    });
  });
</script>
