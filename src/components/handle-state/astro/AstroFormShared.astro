---
import { $formState } from "@stores/handling-state/sharedFormStore";
---

<form id="astroForm" class="bg-astro-100 rounded-lg p-4 text-gray-900 shadow-md">
  <h2 class="text-astro-800 mb-4 text-center text-2xl font-bold">Astro Form (Shared State)</h2>
  <div class="space-y-4">
    <div>
      <label for="astro-firstName" class="text-astro-700 block text-sm font-medium"
        >First Name</label
      >
      <input
        type="text"
        id="astro-firstName"
        name="firstName"
        value={$formState.get().firstName}
        class="border-astro-300 focus:ring-astro-200 mt-1 block w-full rounded-md shadow-xs focus:ring focus:outline-hidden"
      />
    </div>
    <div>
      <label for="astro-lastName" class="text-astro-700 block text-sm font-medium">Last Name</label>
      <input
        type="text"
        id="astro-lastName"
        name="lastName"
        value={$formState.get().lastName}
        class="border-astro-300 focus:ring-astro-200 mt-1 block w-full rounded-md shadow-xs focus:ring focus:outline-hidden"
      />
    </div>
    <div>
      <label for="astro-email" class="text-astro-700 block text-sm font-medium">Email</label>
      <input
        type="email"
        id="astro-email"
        name="email"
        value={$formState.get().email}
        class="border-astro-300 focus:ring-astro-200 mt-1 block w-full rounded-md shadow-xs focus:ring focus:outline-hidden"
      />
    </div>
    <div>
      <label for="astro-password" class="text-astro-700 block text-sm font-medium">Password</label>
      <input
        type="password"
        id="astro-password"
        name="password"
        value={$formState.get().password}
        class="border-astro-300 focus:ring-astro-200 mt-1 block w-full rounded-md shadow-xs focus:ring focus:outline-hidden"
      />
    </div>
    <div class="flex items-center">
      <input
        type="checkbox"
        id="astro-agreeTerms"
        name="agreeTerms"
        checked={$formState.get().agreeTerms}
        class="border-astro-300 text-astro-600 focus:ring-astro-500 h-4 w-4 rounded"
      />
      <label for="astro-agreeTerms" class="text-astro-700 ml-2 block text-sm"
        >I agree to the terms and conditions</label
      >
    </div>
  </div>
  <div class="mt-6">
    <button
      type="submit"
      class="bg-astro-500 hover:bg-astro-600 w-full rounded px-4 py-2 text-white transition-colors"
    >
      Submit
    </button>
  </div>
</form>

<script>
  import { $formState } from "@stores/handling-state/sharedFormStore";

  const form = document.getElementById("astroForm");

  form?.addEventListener("input", (event) => {
    const target = event.target as HTMLInputElement;
    const { name, value, type, checked } = target;
    $formState.setKey(
      name as keyof import("@stores/handling-state/sharedFormStore").FormData,
      type === "checkbox" ? checked : value
    );
  });

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    console.log("Astro Form Submitted:", $formState.get());
  });

  $formState.subscribe((state) => {
    Object.entries(state).forEach(([key, value]) => {
      const element = document.getElementById(`astro-${key}`) as HTMLInputElement;
      if (element) {
        if (element.type === "checkbox") {
          element.checked = value as boolean;
        } else {
          element.value = value as string;
        }
      }
    });
  });
</script>
