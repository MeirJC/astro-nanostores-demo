---
import "../styles/global.css";
import Navbar from "@components/Navbar/Navbar.svelte";
import Footer from "@components/Footer.astro";
import PersistentCounter from "@components/handle-state/persistent/PersistentCounter.astro";

interface Props {
  title: string;
  description: string;
  keywords?: string;
  showPersistent?: boolean;
  ogImage?: string;
  isArticle?: boolean;
}

const {
  title,
  description,
  showPersistent = false,
  ogImage = "/og-image.jpg",
  isArticle = false,
} = Astro.props;

import astroLogo from "@assets/astro-logo-white.svg";
import nanostoresLogo from "@assets/nanostores-logo.svg";

const siteName = "Astro Nanostores Demo";
const currentPath = Astro.url.pathname;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = `${title} | ${siteName}`;

const hashnodeBlog = "https://hashnode.com/@MeirJC";
const publishDate = "2024-09-12T05:15:00Z";
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="author" content="Meir Josef Cohen" />
    <meta name="robots" content="index, follow" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={isArticle ? "article" : "website"} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.url)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.url)} />

    <meta name="theme-color" content="#101826" />

    {
      isArticle && (
        <>
          <meta property="article:publisher" content={hashnodeBlog} />
          <meta property="article:author" content={hashnodeBlog} />
          <meta property="article:published_time" content={publishDate} />
        </>
      )
    }

    {
      isArticle && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "Article",
            headline: title,
            description: description,
            image: new URL(ogImage, Astro.url).href,
            author: {
              "@type": "Person",
              name: "Meir Josef Cohen",
              url: "https://github.com/MeirJC",
            },
            publisher: {
              "@type": "Person",
              name: "Meir Josef Cohen",
            },
            datePublished: publishDate,
            mainEntityOfPage: {
              "@type": "WebPage",
              "@id": canonicalURL.href,
            },
          })}
        />
      )
    }

    {
      !isArticle && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "WebSite",
            name: siteName,
            url: Astro.site?.href,
            description:
              "Explore state management in Astro using Nanostores across multiple frameworks.",
            author: {
              "@type": "Person",
              name: "Meir Josef Cohen",
            },
          })}
        />
      )
    }

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="bg-image text-beige flex min-h-screen flex-col overflow-x-hidden bg-gray-900">
    <Navbar
      client:load
      astroLogo={astroLogo.src}
      nanostoresLogo={nanostoresLogo.src}
      currentPath={currentPath}
    />

    <main class="relative container pt-24">
      <slot />
      {showPersistent && <PersistentCounter />}
    </main>
    <Footer />
  </body>
</html>
<style is:global>
  html {
    font-family: system-ui, sans-serif;
  }
</style>
